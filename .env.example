# Application
PROJECT_NAME="AI Recruitment Platform"
API_V1_STR="/api/v1"
SECRET_KEY="your-super-secret-jwt-key-change-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/recruitment_db"
SYNC_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recruitment_db"

# Redis Caching & Task Queue
REDIS_URL="redis://localhost:6379/0"

# AI / LLM Providers
OPENAI_API_KEY="sk-..."
GROQ_API_KEY="gsk_..."
ANTHROPIC_API_KEY="sk-ant-..."
DEFAULT_LLM_PROVIDER="groq" # openai, groq, or anthropic
DEFAULT_LLM_MODEL="llama-3.3-70b-versatile"
EMBEDDING_MODEL="text-embedding-3-small"
